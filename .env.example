# ==============================================================================
# Speech-to-Text Application Environment Variables Configuration Template
# ==============================================================================
# Copy this file to `.env` in the root (or frontend/.env.local and backend/.env)
# and fill in your secrets and configuration values.

# ------------------------------------------------------------------------------
# Backend Configuration (Flask)
# ------------------------------------------------------------------------------
FLASK_APP=app.py
FLASK_ENV=development
PORT=5000

# Speech-to-Text APIs
# Choose your preferred provider and obtain an API key:
# - DeepInfra: https://deepinfra.com/
# - Google Cloud: https://cloud.google.com/speech-to-text
DEEPINFRA_API_KEY=your_deepinfra_api_key_here
# GOOGLE_APPLICATION_CREDENTIALS=path/to/google-key.json

# Database Configurations (Supabase / PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/speech_to_text

# JWT Authentication Secret Key
JWT_SECRET=your_jwt_secret_here_change_in_production

# ------------------------------------------------------------------------------
# Frontend Configuration (Next.js)
# ------------------------------------------------------------------------------
# API endpoints that frontend should query:
NEXT_PUBLIC_API_URL=http://localhost:5000
